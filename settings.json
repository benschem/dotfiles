{
  "editor.bracketPairColorization.enabled": true,
  "editor.tabSize": 2,
  "editor.detectIndentation": true,
  "editor.fontSize": 14,
  "editor.guides.bracketPairs": true,
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.renderControlCharacters": true,
  "editor.rulers": [80, 120],
  "editor.showFoldingControls": "always",
  "editor.snippetSuggestions": "top",
  "emmet.includeLanguages": {
    "erb": "html"
  },
  "emmet.showSuggestionsAsSnippets": true,
  "emmet.triggerExpansionOnTab": true,
  "explorer.confirmDelete": false,
  "files.exclude": {
    "__pycache__": true,
    "_site": true,
    ".asset-cache": true,
    ".bundle": true,
    ".ipynb_checkpoints": true,
    ".pytest_cache": true,
    ".sass-cache": true,
    ".svn": true,
    "**/.DS_Store": true,
    "**/.egg-info": true,
    "**/.git": true,
    "build": true,
    "coverage": true,
    "dist": true,
    "log": true,
    "node_modules": true,
    "public/packs": true,
    "tmp": true
  },
  "files.hotExit": "onExit",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "files.watcherExclude": {
    "**/audits/**": true,
    "**/coverage/**": true,
    "**/log/**": true,
    "**/node_modules/**": true,
    "**/tmp/**": true,
    "**/vendor/**": true
  },
  "search.exclude": {
    // Inherits all glob patterns from the `files.exclude` setting.
    "**/.venv": true
  },
  "telemetry.telemetryLevel": "off",
  "window.restoreWindows": "none",
  "window.newWindowDimensions": "offset",
  "workbench.editor.enablePreview": false,
  "workbench.iconTheme": "vscode-great-icons",
  "workbench.settings.editor": "json",
  "workbench.settings.openDefaultSettings": true,
  "workbench.settings.useSplitJSON": true,
  "workbench.startupEditor": "none",
  "workbench.panel.defaultLocation": "right",
  "editor.renderWhitespace": "trailing",
  "workbench.editor.untitled.hint": "hidden",
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.formatOnSave": true,
  "prettier.enableDebugLogs": false,
  "sass.format.convert": false,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "tailwindCSS.emmetCompletions": true,
  "editor.accessibilitySupport": "off",
  "editor.inlayHints.enabled": "on",
  "workbench.colorCustomizations": {
    "editor.lineHighlightBackground": "#1073cf2d",
    "editor.lineHighlightBorder": "#9fced11f"
  },
  "editor.wordWrap": "off",
  "diffEditor.wordWrap": "off",
  "editor.guides.indentation": true,
  "[erb]": {
    "editor.formatOnSave": true
  },
  "files.associations": {
    "*.erb": "erb"
  },
  "workbench.editor.empty.hint": "hidden",
  "diffEditor.renderSideBySide": true,
  "css.format.spaceAroundSelectorSeparator": true,
  "less.format.spaceAroundSelectorSeparator": true,
  "scss.format.spaceAroundSelectorSeparator": true,
  "html.format.templating": true,
  "html.format.contentUnformatted": "",
  "editor.renderLineHighlight": "gutter",
  "editor.renderLineHighlightOnlyWhenFocus": true,
  "editor.semanticHighlighting.enabled": true,
  "editor.wordWrapColumn": 120,
  "prettier.printWidth": 120,
  "prettier.singleAttributePerLine": true,
  "cssvar.files": ["**/*.css"],
  "cssvar.ignore": [],
  "update.showReleaseNotes": false,
  "explorer.confirmPasteNative": false,
  "chat.commandCenter.enabled": false,
  "chat.agent.maxRequests": 0,
  "git.path": "/usr/local/bin/git",
  "css.lint.duplicateProperties": "warning",
  "css.lint.float": "warning",
  "css.lint.hexColorLength": "warning",
  "css.autoValidation": "Always",
  "workbench.activityBar.location": "hidden",
  "rubyLsp.enabledFeatures": {
    "codeActions": true,
    "diagnostics": true,
    "documentHighlights": true,
    "documentLink": true,
    "documentSymbols": true,
    "foldingRanges": true,
    "formatting": true,
    "hover": true,
    "inlayHint": true,
    "onTypeFormatting": true,
    "selectionRanges": true,
    "semanticHighlighting": true,
    "completion": true,
    "codeLens": false,
    "definition": true,
    "workspaceSymbol": true,
    "signatureHelp": true,
    "typeHierarchy": true
  },
  "workbench.layoutControl.enabled": false,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.size": "fit",
  "files.autoSave": "afterDelay",
  "indentRainbow.errorColor": "rgba(128,32,32,0.1)",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "eslint.format.enable": true,
  "eslint.useFlatConfig": true,
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "typescript.updateImportsOnFileMove.enabled": "always",
  "rubyLsp.linters": ["rubocop"],
  "workbench.colorTheme": "GitHub Dark Default",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "diffEditor.ignoreTrimWhitespace": false
}
